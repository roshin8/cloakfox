# Cloakfox extension — popup-only since the cpp-first refactor.
# All fingerprint-spoofing logic lives in C++ patches + chrome-
# privileged JSWindowActors (browser/components/cloakfox/actors/).
# This extension exists only to host the toolbar popup; nothing
# touches page content.

browser.jar:
    builtin-addons/cloakfox-shield/manifest.json       (manifest.json)
    builtin-addons/cloakfox-shield/popup/popup.html    (popup/popup.html)
    builtin-addons/cloakfox-shield/popup/popup.js      (popup/popup.js)
    builtin-addons/cloakfox-shield/popup/popup.css     (popup/popup.css)
    builtin-addons/cloakfox-shield/icons/icon-48.png   (icons/icon-48.png)
    builtin-addons/cloakfox-shield/icons/icon-128.png  (icons/icon-128.png)
    builtin-addons/cloakfox-shield/experiment-apis/cloakfox.json (experiment-apis/cloakfox.json)
    builtin-addons/cloakfox-shield/experiment-apis/cloakfox.js   (experiment-apis/cloakfox.js)
