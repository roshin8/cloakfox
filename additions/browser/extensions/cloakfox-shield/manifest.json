{
  "manifest_version": 3,
  "name": "Cloakfox",
  "version": "0.6.0",
  "description": "Tab-aware indicator for the Cloakfox per-container fingerprint isolation engine. All spoofing happens in the browser core; this extension only provides the toolbar popup.",
  "author": "Cloakfox",
  "homepage_url": "https://github.com/roshin8/cloakfox",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-128.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "contextualIdentities"
  ],
  "experiment_apis": {
    "cloakfox": {
      "schema": "api/cloakfox_api.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "api/cloakfox_api.js",
        "paths": [["cloakfox"]]
      }
    }
  },
  "action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-128.png"
    },
    "default_title": "Cloakfox",
    "default_popup": "popup/popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "MacCtrl+Shift+C"
      },
      "description": "Open Cloakfox popup"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cloakfox-shield@cloakfox",
      "strict_min_version": "128.0"
    }
  }
}
