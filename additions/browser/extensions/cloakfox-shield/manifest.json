{
  "manifest_version": 2,
  "name": "Cloakfox",
  "version": "0.6.0",
  "description": "Tab-aware toolbar popup for Cloakfox per-container fingerprint isolation. Surfaces the active container's persona, lets you regenerate it, and links to the full settings page.",
  "author": "Cloakfox",
  "homepage_url": "https://github.com/roshin8/cloakfox",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-128.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "contextualIdentities"
  ],
  "experiment_apis": {
    "cloakfox": {
      "schema": "experiment-apis/cloakfox.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiment-apis/cloakfox.js",
        "events": ["startup"],
        "paths": [["cloakfox"]]
      }
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-128.png"
    },
    "default_title": "Cloakfox",
    "default_popup": "popup/popup.html"
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "MacCtrl+Shift+C"
      },
      "description": "Open Cloakfox popup"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cloakfox-shield@cloakfox",
      "strict_min_version": "128.0"
    }
  }
}
