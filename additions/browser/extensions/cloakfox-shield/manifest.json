{
  "manifest_version": 3,
  "name": "Cloakfox Shield",
  "version": "0.5.0",
  "description": "Per-container fingerprint spoofing with C++ engine integration for Cloakfox browser",
  "author": "Cloakfox",
  "homepage_url": "https://github.com/roshin8/cloakfox",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-128.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "contextualIdentities",
    "cookies",
    "tabs",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "privacy",
    "notifications",
    "contextMenus",
    "alarms",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background/index.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "inject/index.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/index.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pages/ip-warning.html",
        "pages/test-runner.html",
        "icons/*.svg",
        "chunks/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-128.png"
    },
    "default_title": "Cloakfox Shield",
    "default_popup": "popup/index.html"
  },
  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": true
  },
  "commands": {
    "toggle-protection": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "MacCtrl+Shift+P"
      },
      "description": "Toggle fingerprint protection for current container"
    },
    "rotate-fingerprint": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "MacCtrl+Shift+R"
      },
      "description": "Rotate fingerprint for current container"
    },
    "toggle-site-exception": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "MacCtrl+Shift+E"
      },
      "description": "Toggle protection exception for current site"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "MacCtrl+Shift+C"
      },
      "description": "Open Cloakfox Shield popup"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cloakfox-shield@cloakfox",
      "strict_min_version": "128.0"
    }
  }
}