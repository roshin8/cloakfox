+/* static */ nsCString
+RoverfoxStorageManager::MakeCppFirstPrefName(const nsAString& key) {
+  // cpp-first pref namespace — written by about:cloakfox (chrome-
+  // privileged). Takes priority over roverfox.s.* (extension-written).
+  nsAutoCString prefName("cloakfox.s.");
+  AppendUTF16toUTF8(key, prefName);
+  return nsCString(prefName);
+}
+
+/* static */ bool
+RoverfoxStorageManager::TryGetCppFirstPref(const nsAString& key,
+                                            nsACString& outValue) {
+  nsCString prefName = MakeCppFirstPrefName(key);
+  nsAutoCString v;
+  nsresult rv = Preferences::GetCString(prefName.get(), v);
+  // DIAGNOSTIC (temporary — strip before RFC lands): trace every
+  // call so we can see what path TryGetCppFirstPref takes in each
+  // process.
+  printf_stderr("CFX-TRYCPP: key=%s rv=%x v='%s' parent=%d\n",
+                prefName.get(), uint32_t(rv), v.get(),
+                XRE_IsParentProcess() ? 1 : 0);
+  if (NS_SUCCEEDED(rv) && !v.IsEmpty()) {
+    outValue = v;
+    return true;
+  }
+  if (!XRE_IsParentProcess() && NS_IsMainThread()) {
+    ContentChild* cc = ContentChild::GetSingleton();
+    if (cc) {
+      cc->SendRoverfoxStorageGet(prefName, &v);
+      printf_stderr("CFX-TRYCPP-IPC: key=%s v='%s'\n",
+                    prefName.get(), v.get());
+      if (!v.IsEmpty()) {
+        outValue = v;
+        return true;
+      }
+    }
+  }
+  return false;
+}
