+/* static */ nsCString
+RoverfoxStorageManager::MakeCppFirstPrefName(const nsAString& key) {
+  // cpp-first pref namespace — written by about:cloakfox (chrome-
+  // privileged). Takes priority over roverfox.s.* (extension-written).
+  nsAutoCString prefName("cloakfox.s.");
+  AppendUTF16toUTF8(key, prefName);
+  return nsCString(prefName);
+}
+
+/* static */ bool
+RoverfoxStorageManager::TryGetCppFirstPref(const nsAString& key,
+                                            nsACString& outValue) {
+  nsCString prefName = MakeCppFirstPrefName(key);
+  nsAutoCString v;
+  // Parent process or pref already cached in this content process.
+  if (NS_SUCCEEDED(Preferences::GetCString(prefName.get(), v)) && !v.IsEmpty()) {
+    outValue = v;
+    return true;
+  }
+  // Content-process fallback: user-set prefs under our namespace aren't
+  // automatically mirrored into content processes. Go over the existing
+  // RoverfoxStorageGet IPC channel (the parent handler in ContentParent
+  // accepts both roverfox.s.* and cloakfox.s.* prefixes).
+  if (!XRE_IsParentProcess() && NS_IsMainThread()) {
+    ContentChild* cc = ContentChild::GetSingleton();
+    if (cc) {
+      cc->SendRoverfoxStorageGet(prefName, &v);
+      if (!v.IsEmpty()) {
+        outValue = v;
+        return true;
+      }
+    }
+  }
+  return false;
+}
