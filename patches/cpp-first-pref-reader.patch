+/* static */ nsCString
+RoverfoxStorageManager::MakeCppFirstPrefName(const nsAString& key) {
+  // cpp-first pref namespace — written by about:cloakfox (chrome-
+  // privileged). Takes priority over roverfox.s.* (extension-written).
+  nsAutoCString prefName("cloakfox.s.");
+  AppendUTF16toUTF8(key, prefName);
+  return nsCString(prefName);
+}
+
+/* static */ bool
+RoverfoxStorageManager::TryGetCppFirstPref(const nsAString& key,
+                                            nsACString& outValue) {
+  nsAutoCString v;
+  if (NS_SUCCEEDED(Preferences::GetCString(MakeCppFirstPrefName(key).get(), v))
+      && !v.IsEmpty()) {
+    outValue = v;
+    return true;
+  }
+  return false;
+}
