+// Cloakfox: WebIDL Func gate — only the cloakfox-shield extension's
+// content scripts (which run with an ExpandedPrincipal containing the
+// addon's principal) can see cloakfoxIsConfigured on the window. Page
+// scripts in MAIN world get an undefined property: they can't probe
+// whether Cloakfox is installed by checking for this method.
+/* static */
+bool nsGlobalWindowInner::IsCloakfoxShieldCaller(JSContext* aCx,
+                                                  JSObject* /*aObj*/) {
+  nsIPrincipal* principal = nsContentUtils::SubjectPrincipal(aCx);
+  if (!principal) {
+    return false;
+  }
+  auto* basePrincipal = mozilla::BasePrincipal::Cast(principal);
+  // Direct addon principal (background scripts, options pages, etc.)
+  if (auto* policy = basePrincipal->AddonPolicy()) {
+    return policy->Id()->Equals(u"cloakfox-shield@cloakfox"_ns);
+  }
+  // Content script ExpandedPrincipal — the common case for ISOLATED-world
+  // content scripts that Want to call this from a page context.
+  if (auto* policy = basePrincipal->ContentScriptAddonPolicy()) {
+    return policy->Id()->Equals(u"cloakfox-shield@cloakfox"_ns);
+  }
+  return false;
+}
+
+// Cloakfox: NON-self-destructing query for whether a per-container
+// spoofer manager has been configured already. Used by the extension's
+// core-bridge.ts to decide whether to add a signal to the `handled`
+// set on second+ navigations, where the matching setXxx WebIDL
+// method has been Func-gated off (callCore returns false). Without
+// this query the JS fallback runs on every nav after the first and
+// double-spoofs over the C++ stored value.
+bool nsGlobalWindowInner::CloakfoxIsConfigured(const nsAString& aName,
+                                                ErrorResult& aRv) {
+  JSContext* cx = nsContentUtils::GetCurrentJSContext();
+  if (!cx) return false;
+  JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+  if (!global) return false;
+  NS_ConvertUTF16toUTF8 utf8(aName);
+  if (utf8.EqualsLiteral("canvas")) {
+    return !mozilla::dom::CanvasFingerprintManager::IsFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("screen")) {
+    return !mozilla::dom::ScreenDimensionManager::IsFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("webglVendor")) {
+    return !mozilla::dom::WebGLParamsManager::IsVendorFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("webglRenderer")) {
+    return !mozilla::dom::WebGLParamsManager::IsRendererFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("fontList")) {
+    return !mozilla::dom::FontListManager::IsFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("fontSpacing")) {
+    return !mozilla::dom::FontSpacingSeedManager::IsFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("audio")) {
+    return !mozilla::dom::AudioFingerprintManager::IsFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("speechVoices")) {
+    return !mozilla::dom::SpeechVoicesManager::IsFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("navigatorUserAgent")) {
+    return !mozilla::dom::NavigatorManager::IsUaFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("navigatorPlatform")) {
+    return !mozilla::dom::NavigatorManager::IsPlatformFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("navigatorOscpu")) {
+    return !mozilla::dom::NavigatorManager::IsOscpuFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  if (utf8.EqualsLiteral("navigatorHardwareConcurrency")) {
+    return !mozilla::dom::NavigatorManager::IsHwcFunctionEnabledForWebIDL(
+        cx, global);
+  }
+  return false;
+}
+
+void nsGlobalWindowInner::SetHttp3Profile(const nsAString& aProfile,
+                                          ErrorResult& aRv) {
+  NS_ConvertUTF16toUTF8 utf8(aProfile);
+  uint32_t value;
+  if (utf8.EqualsLiteral("firefox")) {
+    value = 0;
+  } else if (utf8.EqualsLiteral("chrome")) {
+    value = 1;
+  } else if (utf8.EqualsLiteral("safari")) {
+    value = 2;
+  } else {
+    return;
+  }
+  Preferences::SetUint("network.http.http3.fingerprint_profile", value);
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(cx, JS::UndefinedValue());
+      JS_SetProperty(cx, global, "setHttp3Profile", undef);
+      JS_DeleteProperty(cx, global, "setHttp3Profile");
     }
   }
 }
