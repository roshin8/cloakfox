+# Cloakfox: HTTP/3 fingerprint profile (Akamai h3fp / JA4H).
+# Reshapes the SETTINGS frame emitted on the H3 control stream and the
+# QPACK transport parameters to match the target browser.
+#   0 => firefox (default, no change)
+#   1 => chrome
+#   2 => safari
+# See patches/http3-fingerprint-spoofing.patch for the emitted shapes.
+- name: network.http.http3.fingerprint_profile
