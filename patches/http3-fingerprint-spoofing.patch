@@ -19,6 +19,31 @@
 const CONNECT_DEFAULT: bool = false;
 const HTTP3_DATAGRAM_DEFAULT: bool = true;
 
+/// Cloakfox: HTTP/3 fingerprint profile (Akamai h3fp / JA4H input).
+/// Selects which SETTINGS frame shape the client emits on its control
+/// stream. Matches `network.http.http3.fingerprint_profile`:
+///   0 => Firefox (default — original neqo emission order and set)
+///   1 => Chrome  (different order, extra max_header_list_size)
+///   2 => Safari  (sparse, just QPACK_MAX_TABLE_CAPACITY + BLOCKED_STREAMS)
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Default)]
+pub enum H3FingerprintProfile {
+    #[default]
+    Firefox,
+    Chrome,
+    Safari,
+}
+
+impl H3FingerprintProfile {
+    #[must_use]
+    pub const fn from_pref(v: u32) -> Self {
+        match v {
+            1 => Self::Chrome,
+            2 => Self::Safari,
+            _ => Self::Firefox,
+        }
+    }
+}
+
 #[derive(Debug, Clone)]
 pub struct Http3Parameters {
     conn_params: ConnectionParameters,
@@ -28,6 +53,8 @@
