+/* Cloakfox: Per-context MaskConfig overlay via RoverfoxStorageManager. */
+#include "RoverfoxStorageManager.h"
+#include "json.hpp"
+#include "nsString.h"
+#include <string>
+
+std::string CloakConfigOverlay_Get(uint32_t userContextId) {
+  nsAutoString key;
+  key.AppendPrintf("cloak_cfg_%u", userContextId);
+  nsAutoString value;
+  if (mozilla::dom::RoverfoxStorageManager::GetString(key, value)) {
+    NS_ConvertUTF16toUTF8 utf8(value);
+    return std::string(utf8.get());
+  }
+  return "";
+}
+
+void CloakConfigOverlay_Set(uint32_t userContextId, const std::string& jsonStr) {
+  nsAutoString key;
+  key.AppendPrintf("cloak_cfg_%u", userContextId);
+  NS_ConvertUTF8toUTF16 value(jsonStr.c_str());
+  mozilla::dom::RoverfoxStorageManager::PutString(key, value);
+}
+
+void CloakConfigOverlay_MergeUint(uint32_t userContextId, const std::string& key, uint32_t value) {
+  std::string current = CloakConfigOverlay_Get(userContextId);
+  nlohmann::json j = current.empty() ? nlohmann::json{} :
+    (nlohmann::json::accept(current) ? nlohmann::json::parse(current) : nlohmann::json{});
+  j[key] = value;
+  CloakConfigOverlay_Set(userContextId, j.dump());
+}
+
+void CloakConfigOverlay_MergeString(uint32_t userContextId, const std::string& key, const std::string& value) {
+  std::string current = CloakConfigOverlay_Get(userContextId);
+  nlohmann::json j = current.empty() ? nlohmann::json{} :
+    (nlohmann::json::accept(current) ? nlohmann::json::parse(current) : nlohmann::json{});
+  j[key] = value;
+  CloakConfigOverlay_Set(userContextId, j.dump());
+}
