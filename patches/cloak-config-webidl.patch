+// Per-context config overlay set by extension via window.setCloakConfig(json).
+// Stored in RoverfoxStorageManager as "cloak_cfg_{userContextId}" for cross-process safety.
+// Priority: per-context overlay > CLOAK_CONFIG env var > real values.
+
+inline nlohmann::json GetContextOverlay(uint32_t userContextId = 0) {
+  // Read JSON string from RoverfoxStorageManager
+  // Key format: "cloak_cfg_0" for default, "cloak_cfg_1" for container 1, etc.
+  // This is called from various threads, but RoverfoxStorageManager uses
+  // Firefox Preferences which are cross-process safe.
+  nsAutoString key;
+  key.AppendPrintf("cloak_cfg_%u", userContextId);
+  nsAutoString value;
+  if (RoverfoxStorageManager::GetString(key, value)) {
+    NS_ConvertUTF16toUTF8 utf8(value);
+    std::string jsonStr(utf8.get());
+    if (!jsonStr.empty() && nlohmann::json::accept(jsonStr)) {
+      return nlohmann::json::parse(jsonStr);
+    }
+  }
+  return nlohmann::json{};
+}
+
+inline void SetContextOverlay(uint32_t userContextId, const std::string& jsonStr) {
+  nsAutoString key;
+  key.AppendPrintf("cloak_cfg_%u", userContextId);
+  nsAutoString value;
+  value.Assign(NS_ConvertUTF8toUTF16(jsonStr.c_str()));
+  RoverfoxStorageManager::PutString(key, value);
+}
+
 inline bool HasKey(const std::string& key, const nlohmann::json& data) {
