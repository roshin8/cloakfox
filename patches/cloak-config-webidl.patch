+void nsGlobalWindowInner::SetCloakConfig(const nsAString& aJson,
+                                          ErrorResult& aRv) {
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+  NS_ConvertUTF16toUTF8 utf8(aJson);
+  std::string jsonStr(utf8.get());
+  CloakConfigOverlay_Set(userContextId, jsonStr);
+  if (userContextId != 0) CloakConfigOverlay_Set(0, jsonStr);
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(cx, JS::UndefinedValue());
+      JS_SetProperty(cx, global, "setCloakConfig", undef);
+      JS_DeleteProperty(cx, global, "setCloakConfig");
     }
   }
 }
