+void nsGlobalWindowInner::SetBatteryStatus(bool aCharging, double aLevel,
+                                            ErrorResult& aRv) {
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+  BatteryStatusManager::SetCharging(userContextId, aCharging);
+  BatteryStatusManager::SetLevel(userContextId, aLevel);
+  if (userContextId != 0) {
+    BatteryStatusManager::SetCharging(0, aCharging);
+    BatteryStatusManager::SetLevel(0, aLevel);
+  }
+  BatteryStatusManager::DisableFunction(userContextId);
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(cx, JS::UndefinedValue());
+      JS_SetProperty(cx, global, "setBatteryStatus", undef);
+      JS_DeleteProperty(cx, global, "setBatteryStatus");
     }
   }
 }
