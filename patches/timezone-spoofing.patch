+void nsGlobalWindowInner::SetTimezone(const nsAString& timezone, ErrorResult& aRv) {
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+
+  NS_LossyConvertUTF16toASCII timezoneASCII(timezone);
+
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    if (!JS::SetRealmTimeZoneOverride(cx, timezoneASCII.get())) {
+      aRv.ThrowTypeError("Invalid timezone identifier");
+      return;
+    }
+  }
+
+  TimezoneManager::SetTimezone(userContextId, timezone);
+
+  // Also store under userContextId=0 as fallback for shared/service workers
+  // which may have a different userContextId than the parent page.
+  if (userContextId != 0) {
+    TimezoneManager::SetTimezone(0, timezone);
+  }
+
+  // Set global process-wide timezone as ultimate fallback.
+  // Per-realm overrides (windows + dedicated workers) take priority.
+  // Shared/service workers without per-realm override fall back to this.
+  JS::SetTimeZoneOverride(timezoneASCII.get());
+
+  // Self-destruct: remove this function from the window object after first use.
+  // Set to undefined first to bust IC/shape caches on ARM64 (macOS Apple Silicon),
+  // then delete. Without this, the resolve hook may not re-fire on ARM64 and the
+  // Func guard never gets checked, causing the property to survive deletion.
+  if (JSContext* selfDestructCx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(selfDestructCx, JS::CurrentGlobalOrNull(selfDestructCx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(selfDestructCx, JS::UndefinedValue());
+      JS_SetProperty(selfDestructCx, global, "setTimezone", undef);
+      JS_DeleteProperty(selfDestructCx, global, "setTimezone");
+    }
+  }
+}
