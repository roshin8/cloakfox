+JS_PUBLIC_API bool JS::SetTimeZoneOverride(const char* timeZoneId) {
+  if (!timeZoneId || *timeZoneId == 0) {
+    return false;
+  }
+  mozilla::Span<const char> tzSpan(timeZoneId, strlen(timeZoneId));
+  auto result = mozilla::intl::TimeZone::SetDefaultTimeZone(tzSpan);
+  if (result.isErr()) {
+    return false;
+  }
+  js::ResetTimeZoneInternal(js::ResetTimeZoneMode::ResetEvenIfOffsetUnchanged);
+  return true;
+}
+
+JS_PUBLIC_API bool JS::SetRealmTimeZoneOverride(JSContext* cx, const char* timeZoneId) {
+  JS::Realm* realm = js::GetContextRealm(cx);
+  if (!realm) {
+    return false;
+  }
+  realm->setTimeZoneOverride(timeZoneId);
+  return true;
+}
