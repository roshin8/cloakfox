+
+void nsGlobalWindowInner::SetMediaDeviceCounts(uint32_t aMics, uint32_t aCams,
+                                                uint32_t aSpeakers, ErrorResult& aRv) {
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+  MediaDeviceCountManager::SetCounts(userContextId, aMics, aCams, aSpeakers);
+  if (userContextId != 0) {
+    MediaDeviceCountManager::SetCounts(0, aMics, aCams, aSpeakers);
+  }
+  MediaDeviceCountManager::DisableFunction(userContextId);
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(cx, JS::UndefinedValue());
+      JS_SetProperty(cx, global, "setMediaDeviceCounts", undef);
+      JS_DeleteProperty(cx, global, "setMediaDeviceCounts");
     }
   }
 }
