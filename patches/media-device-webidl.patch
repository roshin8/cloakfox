+/* Cloakfox: Per-context media device count manager */
+#include "MediaDeviceCountManager.h"
+#include "mozilla/dom/BrowsingContext.h"
+#include "nsGlobalWindowInner.h"
+
+namespace mozilla {
+namespace dom {
+
+void MediaDeviceCountManager::SetCounts(uint32_t aId, uint32_t aMics, uint32_t aCams, uint32_t aSpeakers) {
+  nsAutoString k;
+  k.AppendPrintf("mediadev_mics_%u", aId);
+  RoverfoxStorageManager::PutUint(k, aMics);
+  k.Truncate();
+  k.AppendPrintf("mediadev_cams_%u", aId);
+  RoverfoxStorageManager::PutUint(k, aCams);
+  k.Truncate();
+  k.AppendPrintf("mediadev_spk_%u", aId);
+  RoverfoxStorageManager::PutUint(k, aSpeakers);
+  k.Truncate();
+  k.AppendPrintf("mediadev_set_%u", aId);
+  RoverfoxStorageManager::PutBool(k, true);
+}
+
+bool MediaDeviceCountManager::GetCounts(uint32_t aId, uint32_t& aMics, uint32_t& aCams, uint32_t& aSpeakers) {
+  nsAutoString k;
+  k.AppendPrintf("mediadev_set_%u", aId);
+  bool wasSet = false;
+  if (!RoverfoxStorageManager::GetBool(k, wasSet) || !wasSet) return false;
+  k.Truncate();
+  k.AppendPrintf("mediadev_mics_%u", aId);
+  RoverfoxStorageManager::GetUint(k, aMics);
+  k.Truncate();
+  k.AppendPrintf("mediadev_cams_%u", aId);
+  RoverfoxStorageManager::GetUint(k, aCams);
+  k.Truncate();
+  k.AppendPrintf("mediadev_spk_%u", aId);
+  RoverfoxStorageManager::GetUint(k, aSpeakers);
+  return true;
+}
+
+nsString MediaDeviceCountManager::DisabledKeyForUserContext(uint32_t aId) {
+  nsAutoString key;
+  key.AppendPrintf("mediadev_d_%u", aId);
+  return key;
+}
+
+bool MediaDeviceCountManager::IsFunctionEnabledForWebIDL(JSContext* cx, JSObject* global) {
+  return ManagerBase::IsFunctionEnabledForWebIDLImpl(cx, global);
+}
+
+}  // namespace dom
+}  // namespace mozilla
