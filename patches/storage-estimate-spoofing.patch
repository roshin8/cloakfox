+
+  // Cloakfox: always return false when persisted-status spoofing is enabled
+  if (MaskConfig::GetBool("storage:persisted:disabled").value_or(false)) {
+    RefPtr<Promise> promise = Promise::Create(mOwner, aRv);
+    if (aRv.Failed()) return nullptr;
+    promise->MaybeResolve(false);
