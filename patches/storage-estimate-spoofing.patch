@@ -793,6 +802,18 @@
 already_AddRefed<Promise> StorageManager::Estimate(ErrorResult& aRv) {
   MOZ_ASSERT(mOwner);
 
+  // Cloakfox: return spoofed estimate values if configured
+  if (auto quota = MaskConfig::GetUint64("storage:quota")) {
+    RefPtr<Promise> promise = Promise::Create(mOwner, aRv);
+    if (aRv.Failed()) return nullptr;
+    StorageEstimate estimate;
+    estimate.mQuota.Construct(quota.value());
+    estimate.mUsage.Construct(
+        MaskConfig::GetUint64("storage:usage").value_or(0));
+    promise->MaybeResolve(estimate);
+    return promise.forget();
+  }
+
   return ExecuteOpOnMainOrWorkerThread(mOwner, RequestResolver::Type::Estimate,
                                        aRv);
 }
