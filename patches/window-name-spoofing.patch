 void nsGlobalWindowOuter::GetNameOuter(nsAString& aName) {
+  // Cloakfox: block window.name reads if configured
+  if (MaskConfig::GetBool("window:name:disabled").value_or(false)) {
+    aName.Truncate();
+    return;
+  }
   if (mDocShell) {
     mDocShell->GetName(aName);
   }
@@ -3414,6 +3420,10 @@
 
 void nsGlobalWindowOuter::SetNameOuter(const nsAString& aName,
                                        mozilla::ErrorResult& aError) {
+  // Cloakfox: silently ignore window.name writes if configured
+  if (MaskConfig::GetBool("window:name:disabled").value_or(false)) {
+    return;
+  }
   if (mDocShell) {
     aError = mDocShell->SetName(aName);
   }
