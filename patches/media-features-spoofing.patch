 // as a signal.
 StylePrefersContrast Gecko_MediaFeatures_PrefersContrast(
     const Document* aDocument) {
+  // Cloakfox: content-only override — 0=no-pref, 1=less, 2=more, 3=custom
+  if (auto value = MaskConfig::GetInt32("mediaFeature:prefersContrast");
+      value.has_value()) {
+    switch (value.value()) {
+      case 1: return StylePrefersContrast::Less;
+      case 2: return StylePrefersContrast::More;
+      case 3: return StylePrefersContrast::Custom;
+      default: return StylePrefersContrast::NoPreference;
+    }
+  }
