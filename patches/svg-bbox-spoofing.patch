+// Cloakfox: sub-pixel noise on a gfx::Rect for SVG bbox spoofing.
+static gfx::Rect CloakNoiseRect(gfx::Rect aRect) {
+  auto seed = MaskConfig::GetUint32("canvas:seed");
+  if (!seed || seed.value() == 0) return aRect;
+  uint32_t s = seed.value();
+  auto n = [&s]() {
+    s = s * 1664525u + 1013904223u;
+    return (static_cast<float>(s) / 4294967295.0f - 0.5f) * 0.4f;
+  };
+  aRect.x += n();
+  aRect.y += n();
+  aRect.width += n();
+  aRect.height += n();
+  return aRect;
+}
