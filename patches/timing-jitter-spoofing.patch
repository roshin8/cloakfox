+
+// Cloakfox: deterministic timer jitter for fingerprinting resistance.
+// Based on a per-context seed, inject 0-N ms jitter into each SetTimeout/
+// SetInterval call so timing patterns differ across containers.
+static int32_t CloakJitter(int32_t aTimeout) {
+  auto max = MaskConfig::GetUint32("timing:setTimeoutJitter");
+  if (!max || max.value() == 0) return aTimeout;
+  static uint32_t state = MaskConfig::GetUint32("timing:setTimeoutSeed")
+                              .value_or(1);
+  state = state * 1664525u + 1013904223u;
+  return aTimeout + static_cast<int32_t>(state % max.value());
 }
 
