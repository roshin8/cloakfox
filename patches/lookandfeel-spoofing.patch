 nsresult nsXPLookAndFeel::GetIntValue(IntID aID, int32_t& aResult) {
+  // Cloakfox: allow per-context override of system-level media queries.
+  // Extension can set these in cloakConfig JSON — takes precedence over
+  // Firefox prefs and native OS values. Fixes the per-container model
+  // for prefers-color-scheme / reduced-motion / forced-colors / etc.
+  const char* maskKey = nullptr;
+  switch (aID) {
+    case IntID::SystemUsesDarkTheme:       maskKey = "lookAndFeel:systemUsesDarkTheme"; break;
+    case IntID::PrefersReducedMotion:      maskKey = "lookAndFeel:prefersReducedMotion"; break;
+    case IntID::PrefersReducedTransparency:maskKey = "lookAndFeel:prefersReducedTransparency"; break;
+    case IntID::UseAccessibilityTheme:     maskKey = "lookAndFeel:useAccessibilityTheme"; break;
+    case IntID::InvertedColors:            maskKey = "lookAndFeel:invertedColors"; break;
+    case IntID::PrimaryPointerCapabilities:maskKey = "lookAndFeel:primaryPointerCapabilities"; break;
+    case IntID::AllPointerCapabilities:    maskKey = "lookAndFeel:allPointerCapabilities"; break;
+    default: break;
+  }
+  if (maskKey) {
+    if (auto value = MaskConfig::GetInt32(maskKey); value.has_value()) {
+      aResult = value.value();
+      return NS_OK;
+    }
+  }
+
   if (NS_SUCCEEDED(Preferences::GetInt(sIntPrefs[size_t(aID)], &aResult))) {
     return NS_OK;
   }
