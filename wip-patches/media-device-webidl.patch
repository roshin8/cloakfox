+void nsGlobalWindowInner::SetMediaDeviceCounts(uint32_t mics, uint32_t cams,
+                                                uint32_t speakers,
+                                                ErrorResult& aRv) {
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+  MediaDeviceCountManager::SetMics(userContextId, mics);
+  MediaDeviceCountManager::SetCams(userContextId, cams);
+  MediaDeviceCountManager::SetSpeakers(userContextId, speakers);
+  if (userContextId != 0) {
+    MediaDeviceCountManager::SetMics(0, mics);
+    MediaDeviceCountManager::SetCams(0, cams);
+    MediaDeviceCountManager::SetSpeakers(0, speakers);
+  }
+  MediaDeviceCountManager::DisableFunction(userContextId);
+  // Self-destruct: set to undefined first to bust IC/shape caches on ARM64.
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(cx, JS::UndefinedValue());
+      JS_SetProperty(cx, global, "setMediaDeviceCounts", undef);
+      JS_DeleteProperty(cx, global, "setMediaDeviceCounts");
+    }
+  }
+}
