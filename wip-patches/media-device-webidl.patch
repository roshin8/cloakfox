@@ -333,16 +334,37 @@ RefPtr<MediaDeviceSetRefCnt> MediaDevices::FilterExposedDevices(
 
   // Replaces the RFP-based device count spoofing with one that controls the
   // number of devices exposed.
+  // Cloakfox: per-context media device counts from RoverfoxStorageManager
+  // Check per-context values first, fall back to MaskConfig
+  uint32_t perCtxMics = 0, perCtxCams = 0, perCtxSpeakers = 0;
+  bool hasPerCtx = false;
+  {
+    uint32_t ucid = 0;
+    nsCOMPtr<nsPIDOMWindowInner> owner = GetOwner();
+    if (owner) {
+      nsGlobalWindowInner* win = nsGlobalWindowInner::Cast(owner);
+      if (win) {
+        if (BrowsingContext* bc = win->GetBrowsingContext()) {
+          ucid = bc->OriginAttributesRef().mUserContextId;
+        }
+      }
+    }
+    bool hasMics = MediaDeviceCountManager::GetMics(ucid, perCtxMics);
+    bool hasCams = MediaDeviceCountManager::GetCams(ucid, perCtxCams);
+    bool hasSpeakers = MediaDeviceCountManager::GetSpeakers(ucid, perCtxSpeakers);
+    hasPerCtx = hasMics || hasCams || hasSpeakers;
+  }
 
-  if (!MaskConfig::GetBool("mediaDevices:enabled")) {
+  if (!hasPerCtx && !MaskConfig::GetBool("mediaDevices:enabled")) {
     return exposed;
   }
 
-  uint32_t numMics = MaskConfig::GetUint32("mediaDevices:micros").value_or(3);
-  uint32_t numWebcams =
-      MaskConfig::GetUint32("mediaDevices:webcams").value_or(1);
-  uint32_t numSpeakers =
-      MaskConfig::GetUint32("mediaDevices:speakers").value_or(1);
+  uint32_t numMics = hasPerCtx ? perCtxMics
+      : MaskConfig::GetUint32("mediaDevices:micros").value_or(3);
+  uint32_t numWebcams = hasPerCtx ? perCtxCams
+      : MaskConfig::GetUint32("mediaDevices:webcams").value_or(1);
+  uint32_t numSpeakers = hasPerCtx ? perCtxSpeakers
+      : MaskConfig::GetUint32("mediaDevices:speakers").value_or(1);
 
   // Clear existing devices. We'll add our own
   exposed->Clear();
