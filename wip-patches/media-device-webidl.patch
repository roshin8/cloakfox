diff --git a/dom/base/MediaDeviceCountManager.cpp b/dom/base/MediaDeviceCountManager.cpp
new file mode 100644
index 0000000000..abcdef1234
--- /dev/null
+++ b/dom/base/MediaDeviceCountManager.cpp
@@ -0,0 +1,71 @@
+/* Cloakfox: Per-context media device count manager */
+#include "MediaDeviceCountManager.h"
+
+#include "mozilla/dom/BrowsingContext.h"
+#include "nsGlobalWindowInner.h"
+#include "xpcpublic.h"
+
+namespace mozilla {
+namespace dom {
+
+nsString MediaDeviceCountManager::DisabledKeyForUserContext(uint32_t aId) {
+  nsAutoString key;
+  key.AppendPrintf("mediadev_d_%u", aId);
+  return key;
+}
+
+void MediaDeviceCountManager::SetMics(uint32_t aId, uint32_t aCount) {
+  nsAutoString key;
+  key.AppendPrintf("mediadev_mics_%u", aId);
+  RoverfoxStorageManager::PutUint(key, aCount);
+}
+
+bool MediaDeviceCountManager::GetMics(uint32_t aId, uint32_t& aOut) {
+  nsAutoString key;
+  key.AppendPrintf("mediadev_mics_%u", aId);
+  return RoverfoxStorageManager::GetUint(key, aOut) && aOut != 0;
+}
+
+void MediaDeviceCountManager::SetCams(uint32_t aId, uint32_t aCount) {
+  nsAutoString key;
+  key.AppendPrintf("mediadev_cams_%u", aId);
+  RoverfoxStorageManager::PutUint(key, aCount);
+}
+
+bool MediaDeviceCountManager::GetCams(uint32_t aId, uint32_t& aOut) {
+  nsAutoString key;
+  key.AppendPrintf("mediadev_cams_%u", aId);
+  return RoverfoxStorageManager::GetUint(key, aOut) && aOut != 0;
+}
+
+void MediaDeviceCountManager::SetSpeakers(uint32_t aId, uint32_t aCount) {
+  nsAutoString key;
+  key.AppendPrintf("mediadev_speakers_%u", aId);
+  RoverfoxStorageManager::PutUint(key, aCount);
+}
+
+bool MediaDeviceCountManager::GetSpeakers(uint32_t aId, uint32_t& aOut) {
+  nsAutoString key;
+  key.AppendPrintf("mediadev_speakers_%u", aId);
+  return RoverfoxStorageManager::GetUint(key, aOut) && aOut != 0;
+}
+
+void MediaDeviceCountManager::DisableFunction(uint32_t aId) {
+  RoverfoxStorageManager::PutBool(DisabledKeyForUserContext(aId), true);
+}
+
+bool MediaDeviceCountManager::IsFunctionEnabledForWebIDL(JSContext* aCx,
+                                                          JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) return false;
+  uint32_t id = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    id = bc->OriginAttributesRef().mUserContextId;
+  }
+  bool disabled = false;
+  RoverfoxStorageManager::GetBool(DisabledKeyForUserContext(id), disabled);
+  return !disabled;
+}
+
+}  // namespace dom
+}  // namespace mozilla
