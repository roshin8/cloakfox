@@ -0,0 +1,32 @@
+/* Cloakfox: Per-context media device count manager */
+#ifndef mozilla_dom_MediaDeviceCountManager_h
+#define mozilla_dom_MediaDeviceCountManager_h
+
+#include "nsString.h"
+#include "RoverfoxStorageManager.h"
+
+namespace mozilla {
+namespace dom {
+
+class MediaDeviceCountManager {
+ public:
+  static void SetMics(uint32_t aUserContextId, uint32_t aCount);
+  static bool GetMics(uint32_t aUserContextId, uint32_t& aOut);
+
+  static void SetCams(uint32_t aUserContextId, uint32_t aCount);
+  static bool GetCams(uint32_t aUserContextId, uint32_t& aOut);
+
+  static void SetSpeakers(uint32_t aUserContextId, uint32_t aCount);
+  static bool GetSpeakers(uint32_t aUserContextId, uint32_t& aOut);
+
+  static void DisableFunction(uint32_t aId);
+  static bool IsFunctionEnabledForWebIDL(JSContext* aCx, JSObject* aObj);
+
+ private:
+  static nsString DisabledKeyForUserContext(uint32_t aId);
+};
+
+}  // namespace dom
+}  // namespace mozilla
+
+#endif  // mozilla_dom_MediaDeviceCountManager_h
