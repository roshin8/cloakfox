index 0000000000..abcdef1234
--- /dev/null
+++ b/dom/base/BatteryStatusManager.cpp
@@ -0,0 +1,76 @@
+/* Cloakfox: Per-context battery status manager */
+#include "BatteryStatusManager.h"
+
+#include "mozilla/dom/BrowsingContext.h"
+#include "nsGlobalWindowInner.h"
+#include "xpcpublic.h"
+
+namespace mozilla {
+namespace dom {
+
+nsString BatteryStatusManager::DisabledKeyForUserContext(uint32_t aId) {
+  nsAutoString key;
+  key.AppendPrintf("battery_d_%u", aId);
+  return key;
+}
+
+void BatteryStatusManager::SetCharging(uint32_t aId, bool aCharging) {
+  nsAutoString key;
+  key.AppendPrintf("battery_charging_%u", aId);
+  RoverfoxStorageManager::PutBool(key, aCharging);
+  // Store a sentinel so we know a value was explicitly set (even if false)
+  nsAutoString setKey;
+  setKey.AppendPrintf("battery_charging_set_%u", aId);
+  RoverfoxStorageManager::PutBool(setKey, true);
+}
+
+bool BatteryStatusManager::GetCharging(uint32_t aId, bool& aOut) {
+  nsAutoString setKey;
+  setKey.AppendPrintf("battery_charging_set_%u", aId);
+  bool wasSet = false;
+  RoverfoxStorageManager::GetBool(setKey, wasSet);
+  if (!wasSet) return false;
+  nsAutoString key;
+  key.AppendPrintf("battery_charging_%u", aId);
+  RoverfoxStorageManager::GetBool(key, aOut);
+  return true;
+}
+
+void BatteryStatusManager::SetLevel(uint32_t aId, double aLevel) {
+  nsAutoString key;
+  key.AppendPrintf("battery_level_%u", aId);
+  // Store as uint: level * 10000 to preserve 4 decimal places
+  uint32_t stored = static_cast<uint32_t>(aLevel * 10000.0);
+  RoverfoxStorageManager::PutUint(key, stored);
+}
+
+bool BatteryStatusManager::GetLevel(uint32_t aId, double& aOut) {
+  nsAutoString key;
+  key.AppendPrintf("battery_level_%u", aId);
+  uint32_t stored = 0;
+  if (RoverfoxStorageManager::GetUint(key, stored) && stored != 0) {
+    aOut = static_cast<double>(stored) / 10000.0;
+    return true;
+  }
+  return false;
+}
+
+void BatteryStatusManager::DisableFunction(uint32_t aId) {
+  RoverfoxStorageManager::PutBool(DisabledKeyForUserContext(aId), true);
+}
+
+bool BatteryStatusManager::IsFunctionEnabledForWebIDL(JSContext* aCx,
+                                                       JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) return false;
+  uint32_t id = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    id = bc->OriginAttributesRef().mUserContextId;
+  }
+  bool disabled = false;
+  RoverfoxStorageManager::GetBool(DisabledKeyForUserContext(id), disabled);
+  return !disabled;
+}
+
+}  // namespace dom
+}  // namespace mozilla
